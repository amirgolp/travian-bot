# --- Database ---
POSTGRES_USER=travian
POSTGRES_PASSWORD=travian
POSTGRES_DB=travian
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://travian:travian@localhost:5432/travian

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Encryption key for stored account passwords (Fernet key) ---
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# --- Browser / stealth ---
# Where persistent browser profiles live (cookies, storage per account)
BROWSER_PROFILES_DIR=./.profiles
# Run headless in production. Set to "false" locally to watch the bot play.
HEADLESS=true
# Accept range for delays (seconds) between UI actions — humanization
ACTION_DELAY_MIN=0.8
ACTION_DELAY_MAX=3.2
# Per-account soft activity window. Format: HH:MM-HH:MM local to the account
DEFAULT_ACTIVE_HOURS=07:30-23:45
# Max continuous session minutes before the bot logs out and takes a break
MAX_SESSION_MINUTES=95
BREAK_MINUTES_MIN=12
BREAK_MINUTES_MAX=45

# --- Logging ---
LOG_LEVEL=INFO
